PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=12345678
DB_NAME=crm_db

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# MongoDB (request logging)
# If you're running `docker compose up` from `service/`, Mongo is exposed on localhost:27017
MONGO_URI=mongodb://localhost:27017
MONGO_DB=crm_logs

# Optional: automatically expire request logs after N days (0 = keep forever)
REQUEST_LOG_TTL_DAYS=0
